{
  "name": "minipanel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"server,next\" --prefix-colors \"cyan,magenta\" \"npm run server:dev\" \"npm run next:dev\"",
    "server:dev": "tsx watch server/index.ts",
    "next:dev": "next dev -p 3000",
    "build": "next build",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.7",
    "@ant-design/nextjs-registry": "^1.0.0",
    "antd": "^5.14.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "next": "^14.2.3",
    "pg": "^8.11.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "tsx": "^4.11.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.4.5",
    "vitest": "^1.5.3"
  }
}
